# Supabase (Fingerprint DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Clerk (Auth) — third-party JWT integration with Supabase
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# LLM provider — pick ONE. Preference order: Groq > Gemini > Anthropic.
#
# OPTION A (RECOMMENDED, FREE, EASIEST): Groq
#   https://console.groq.com/keys  (~14,400 req/day on llama-3.3-70b, no credit card, no Cloud project)
GROQ_API_KEY=gsk_xxx
# GROQ_EXPLAIN_MODEL=llama-3.3-70b-versatile
# GROQ_GAUNTLET_MODEL=openai/gpt-oss-120b   # MUST support JSON Schema (Llama 3.3 70B does not)

# OPTION B (FREE, more setup): Google Gemini
#   https://aistudio.google.com/apikey  (1500 req/day, requires a Google Cloud project)
GOOGLE_GENERATIVE_AI_API_KEY=AIza_xxx
# GOOGLE_EXPLAIN_MODEL=gemini-2.5-flash
# GOOGLE_GAUNTLET_MODEL=gemini-2.5-pro

# OPTION C (PAID FALLBACK): Anthropic Claude
#   Used only if both GROQ_API_KEY and GOOGLE_GENERATIVE_AI_API_KEY are unset.
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_EXPLAIN_MODEL=claude-haiku-4-5
# ANTHROPIC_GAUNTLET_MODEL=claude-sonnet-4-5

# Professor Radio TTS — optional. Without these, /radio degrades to script-only.
# Provider preference (highest first): Google Cloud > ElevenLabs.
#
# Google Cloud TTS (RECOMMENDED — FREE 1M chars/mo Neural2, no IP blocks):
#   1. https://console.cloud.google.com/apis/library/texttospeech.googleapis.com → ENABLE
#   2. https://console.cloud.google.com/apis/credentials → Create credentials → API key
#   3. (Optional) Restrict the key to "Cloud Text-to-Speech API"
# GOOGLE_CLOUD_TTS_API_KEY=AIza_xxx
#
# ElevenLabs (FREE 10k chars/mo, often blocked on cloud/VPN IPs):
#   https://elevenlabs.io/app/settings/api-keys
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
