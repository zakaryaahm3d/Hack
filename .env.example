# Supabase (Fingerprint DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Clerk (Auth) — third-party JWT integration with Supabase
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Anthropic (Influencer Synthesis Engine + Comprehension Gauntlet)
ANTHROPIC_API_KEY=sk-ant-xxx
# Optional model overrides (defaults: claude-haiku-4-5 / claude-sonnet-4-5)
# ANTHROPIC_EXPLAIN_MODEL=claude-haiku-4-5
# ANTHROPIC_GAUNTLET_MODEL=claude-sonnet-4-5
