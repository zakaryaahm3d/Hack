# Supabase (Fingerprint DB)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Clerk (Auth) — third-party JWT integration with Supabase
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# PostHog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# LLM provider — pick ONE.
#
# OPTION A (RECOMMENDED, FREE): Google Gemini
#   https://aistudio.google.com/apikey  (free tier: 1500 req/day, no credit card)
GOOGLE_GENERATIVE_AI_API_KEY=AIza_xxx
# GOOGLE_EXPLAIN_MODEL=gemini-2.5-flash
# GOOGLE_GAUNTLET_MODEL=gemini-2.5-pro

# OPTION B (PAID FALLBACK): Anthropic Claude
#   Used only if GOOGLE_GENERATIVE_AI_API_KEY is unset.
#   https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_EXPLAIN_MODEL=claude-haiku-4-5
# ANTHROPIC_GAUNTLET_MODEL=claude-sonnet-4-5

# ElevenLabs (Professor Radio TTS) — optional, /radio degrades to script-only without it
# ELEVENLABS_API_KEY=
# ELEVENLABS_MODEL=eleven_turbo_v2_5
